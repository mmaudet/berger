# Generated by Cargo — build artifacts
/target/

# rustfmt backup files
**/*.rs.bk

# MSVC debug symbols
*.pdb

# Berger sidecar SQLite database (incl. WAL/SHM/journal sidecar files)
berger.db*

# Environment files (may carry secrets — never commit)
*.env

# Personal runtime config (the committed reference is berger.example.yaml)
/berger.yaml
