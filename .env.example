# Berger — environment file template.
#
# Copy this file to `.env` and fill in every value referenced by your
# berger.yaml. Berger interpolates ${VAR} placeholders from the environment
# at startup; a ${VAR} whose variable is unset is a fatal startup error.
# `.gitignore` already excludes `.env` — keep your secrets there.
#
# Secrets are left blank below — fill them in. Non-secret values carry an
# example placeholder; replace it with yours.

# --- Bichon (the upstream archiver) -----------------------------------------
BICHON_BASE_URL=https://bichon.example.com
BICHON_API_TOKEN=

# --- Account 1 --------------------------------------------------------------
# BICHON_ACCOUNT_ID is the numeric id from Bichon — see docs/bichon-setup.md.
BICHON_ACCOUNT_ID_1=
IMAP_HOST_1=imap.example.com
IMAP_USER_1=you@example.com
IMAP_PASSWORD_1=

# --- Account 2 --------------------------------------------------------------
# Drop this block (and the second account in berger.yaml) for a single
# mailbox. For more accounts, add _3, _4, … here and in berger.yaml.
BICHON_ACCOUNT_ID_2=
IMAP_HOST_2=imap.gmail.com
IMAP_USER_2=you@gmail.com
IMAP_PASSWORD_2=

# --- LLM classifier ---------------------------------------------------------
# Needed only while berger.yaml keeps its `llm:` block. For a local endpoint
# with no auth, leave LLM_API_KEY unset and delete the `api_key:` line from
# berger.yaml.
LLM_ENDPOINT=https://api.mistral.ai/v1/chat/completions
LLM_MODEL=mistral-small-latest
LLM_API_KEY=

# --- Webhooks ---------------------------------------------------------------
# Needed only for the webhooks your berger.yaml declares. A *_TOKEN may stay
# unset for an endpoint that needs no Authorization header.
WEBHOOK_DRAFT_URL=https://n8n.example.com/webhook/draft
WEBHOOK_DRAFT_TOKEN=
WEBHOOK_URGENT_URL=https://hermes.example.com/webhook/push/urgent
WEBHOOK_DELEGATE_URL=https://n8n.example.com/webhook/delegate
